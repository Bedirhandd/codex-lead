{
  "name": "codex-lead",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.15.0",
  "engines": {
    "node": ">=22.22.1",
    "npm": ">=11"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "rimraf packages/*/dist tmp/tsbuildinfo",
    "dev:web": "npm run dev --workspace @codex-lead/web-ui",
    "build:web": "npm run build --workspace @codex-lead/web-ui",
    "check:web": "npm run check --workspace @codex-lead/web-ui",
    "prebuild": "npm run clean",
    "build": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "vitest run",
    "quality": "npm run build && npm run lint && npm run format:check && npm run typecheck && npm run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,jsonc,md,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
